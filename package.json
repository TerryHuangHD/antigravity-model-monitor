{
  "name": "antigravity-model-monitor",
  "displayName": "Antigravity Model Monitor",
  "description": "Status-bar monitor for Antigravity AI model quotas. Click to manage model and group display names.",
  "version": "0.3.0",
  "publisher": "terryhuanghd",
  "repository": {
    "type": "git",
    "url": "https://github.com/TerryHuangHD/antigravity-model-monitor.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "antigravity",
    "ai",
    "quota",
    "monitor",
    "status bar"
  ],
  "license": "MIT",
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agModelMonitor.openPanel",
        "title": "Open Antigravity Model Monitor",
        "category": "Antigravity Model Monitor"
      },
      {
        "command": "agModelMonitor.refresh",
        "title": "Refresh Antigravity Quota",
        "category": "Antigravity Model Monitor"
      },
      {
        "command": "agModelMonitor.showLogs",
        "title": "Show Logs",
        "category": "Antigravity Model Monitor"
      },
      {
        "command": "agModelMonitor.resetCustomNames",
        "title": "Reset All Custom Names",
        "category": "Antigravity Model Monitor"
      },
      {
        "command": "agModelMonitor.dumpStateKeys",
        "title": "Dump State DB Keys (debug)",
        "category": "Antigravity Model Monitor"
      },
      {
        "command": "agModelMonitor.dumpKeyValue",
        "title": "Inspect State DB Key Value (debug)",
        "category": "Antigravity Model Monitor"
      }
    ],
    "configuration": {
      "title": "Antigravity Model Monitor",
      "properties": {
        "agModelMonitor.refreshIntervalSeconds": {
          "type": "number",
          "default": 120,
          "minimum": 10,
          "maximum": 3600,
          "description": "Interval in seconds between automatic quota refreshes."
        },
        "agModelMonitor.warningThreshold": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 80,
          "description": "Remaining-percentage threshold below which the status bar turns yellow."
        },
        "agModelMonitor.criticalThreshold": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Remaining-percentage threshold below which the status bar turns red."
        },
        "agModelMonitor.notificationsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show toast notifications when a group crosses a threshold."
        },
        "agModelMonitor.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "description": "Log level for the output channel."
        },
        "agModelMonitor.showCreditsInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show available credits in the status bar."
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run build",
    "build": "node scripts/build.js",
    "build:prod": "node scripts/build.js --production",
    "watch": "node scripts/build.js --watch",
    "lint": "eslint src --ext ts",
    "test": "jest",
    "package": "vsce package",
    "vscode:prepublish": "npm run build:prod"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "sql.js": "^1.10.3"
  }
}
