{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": [],
      "label": "npm: build",
      "detail": "node scripts/build.js"
    },
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "group": "build",
      "problemMatcher": {
        "owner": "esbuild",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^\\s*(.+):(\\d+):(\\d+):\\s+(error|warning):\\s+(.+)$",
          "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[build\\] watching",
          "endsPattern": "Done in"
        }
      },
      "label": "npm: watch",
      "detail": "node scripts/build.js --watch"
    }
  ]
}
